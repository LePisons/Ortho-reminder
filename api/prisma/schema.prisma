generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PatientStatus {
  ACTIVE
  PAUSED
  FINISHED
}

model Patient {
  id                 String        @id @default(cuid())
  rut                String        @unique
  fullName           String
  phone              String        @unique
  email              String        @unique
  treatmentStartDate DateTime
  changeFrequency    Int
  wearDaysPerAligner Int           @default(14)
  totalAligners      Int           @default(0)
  currentAligner     Int           @default(0) // 0 implies tracking hasn't started
  trackingStartedAt  DateTime?
  batchPhase         Int           @default(1)
  batchStartDate     DateTime?
  status             PatientStatus @default(ACTIVE)
  avatarUrl          String?
  diagnosis          String?
  treatmentPlan      String?
  observations       String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  whatsappOptedIn    Boolean       @default(false)
  whatsappOptedInAt  DateTime?

  userId              String
  user                User                 @relation(fields: [userId], references: [id])
  messageLogs         MessageLog[]
  clinicalRecords     ClinicalRecord[]
  patientImages       PatientImage[]
  notes               Note[]
  appointments        Appointment[]
  alignerBatches      AlignerBatch[]
  reevaluations       Reevaluation[]
  alignerChangeEvents AlignerChangeEvent[]
  appointmentRecords  AppointmentRecord[]
  onboardingToken     OnboardingToken?
}

model ClinicalRecord {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  diagnosis     String?
  treatmentPlan String?
  observations  String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

enum ImageType {
  PHOTO
  XRAY
}

model PatientImage {
  id          String    @id @default(cuid())
  url         String
  type        ImageType
  date        DateTime  @default(now())
  description String?
  category    String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  content   String
  color     String?  @default("yellow") // yellow, blue, pink, green
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Appointment {
  id          String            @id @default(cuid())
  title       String
  start       DateTime
  end         DateTime
  allDay      Boolean           @default(false)
  status      AppointmentStatus @default(SCHEDULED)
  description String?

  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id])

  todoistTaskId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// MessageLog replaced by the new version at the bottom

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  patients  Patient[]
}

enum BatchStatus {
  NEEDED
  ORDER_SENT
  IN_PRODUCTION
  DELIVERED_TO_CLINIC
  HANDED_TO_PATIENT
  CANCELLED
}

model AlignerBatch {
  id                   String      @id @default(cuid())
  status               BatchStatus @default(NEEDED)
  orderDate            DateTime?
  expectedDeliveryDate DateTime?
  actualDeliveryDate   DateTime?
  notes                String?
  batchNumber          Int         @default(1)
  alignerCount         Int         @default(0)
  gooFileUrl           String?
  technicianEmail      String?
  technicianNotes      String?
  createdBy            String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  batchEvents BatchEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BatchEvent {
  id         String       @id @default(cuid())
  batchId    String
  batch      AlignerBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  fromStatus BatchStatus?
  toStatus   BatchStatus
  note       String?
  createdBy  String?

  createdAt DateTime @default(now())
}

enum ReevaluationStatus {
  NEEDED
  SCAN_UPLOADED
  APPROVED
}

model Reevaluation {
  id           String             @id @default(cuid())
  status       ReevaluationStatus @default(NEEDED)
  scanDate     DateTime?
  scanFileUrl  String?
  approvalDate DateTime?
  notes        String?
  createdBy    String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MessageChannel {
  WHATSAPP
  EMAIL
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageTemplateType {
  ALIGNER_CHANGE_REMINDER
  APPOINTMENT_REMINDER_48H
  APPOINTMENT_REMINDER_2H
  BATCH_PICKUP_READY
  LAB_ORDER_REQUEST
  PROGRESS_MILESTONE_50
  MISSED_APPOINTMENT
  ORTHODONTIST_ALERT_BATCH_URGENT
  ORTHODONTIST_ALERT_WEEKLY_SUMMARY
  ORTHODONTIST_ALERT_OVERDUE_DELIVERY
  TREATMENT_COMPLETED
  WELCOME
  CHANGE_CONFIRMATION
  CHANGE_FOLLOWUP_NO
  FALLBACK_UNRECOGNIZED
}

model MessageTemplate {
  id        String              @id @default(cuid())
  name      String              @unique
  type      MessageTemplateType
  channel   MessageChannel
  content   String
  language  String              @default("es")
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  logs      MessageLog[]
}

model MessageLog {
  id           String           @id @default(cuid())
  patientId    String?
  templateId   String?
  template     MessageTemplate? @relation(fields: [templateId], references: [id])
  channel      MessageChannel
  recipient    String
  content      String
  status            MessageStatus    @default(PENDING)
  error             String?
  providerMessageId String?          @unique
  triggeredBy  String           // "cron" | "manual" | "telegram_bot"
  createdAt    DateTime         @default(now())

  patient      Patient?         @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model AlignerChangeEvent {
  id             String   @id @default(cuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  alignerNumber  Int
  confirmedAt    DateTime?
  confirmedBy    String?   // "bot_reply" | "manual" | "auto"
  nextReminderAt DateTime
  createdAt      DateTime @default(now())
}

model AppointmentRecord {
  id               String    @id @default(cuid())
  patientId        String
  patient          Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentDate  DateTime
  alignersGiven    Int
  startingAligner  Int
  nextApptEstimate DateTime?
  createdAt        DateTime  @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model OnboardingToken {
  id          String    @id @default(cuid())
  patientId   String    @unique
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  token       String    @unique @default(cuid())
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
}
