generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PatientStatus {
  ACTIVE
  PAUSED
  FINISHED
}

enum PipelineStage {
  REQUIRED_FILES
  IN_PRODUCTION
  READY_FOR_PICKUP
  IN_TREATMENT
  ENDING_SOON
  REEVALUATION
}

// Lowercase members deliberately match the string values already written by the
// app and present in historical rows, so the text->enum migration casts cleanly.
enum MessageTrigger {
  cron
  manual
  webhook
  telegram_bot
}

enum AlignerChangeReason {
  manual_adjustment
  manual_start
  onboarding
  auto_onboarding
  cron
  patient_reply
}

model Patient {
  id                 String        @id @default(cuid())
  rut                String
  fullName           String
  phone              String
  email              String
  treatmentStartDate DateTime
  changeFrequency    Int
  wearDaysPerAligner Int           @default(14)
  totalAligners      Int           @default(0)
  currentAligner     Int           @default(0) // 0 implies tracking hasn't started
  lastAlignerSetAt   DateTime?     // Anchor date for cron scheduling; reset on every manual/auto aligner change
  trackingStartedAt  DateTime?
  batchPhase         Int           @default(1)
  batchStartDate     DateTime?
  lastAppointmentDate DateTime?
  pipelineOverride   PipelineStage? // null = auto-calculated; otherwise a manual stage override
  status             PatientStatus @default(ACTIVE)
  avatarUrl          String?
  diagnosis          String?
  treatmentPlan      String?
  observations       String?
  clinic             String?       // referring dental office
  doctor             String?       // referring colleague / dentist
  dentalinkId        Int?          // links to the Dentalink patient ID (Controles + clinical history)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?     // soft delete; non-null rows are hidden from queries
  whatsappOptedIn    Boolean       @default(false)
  whatsappOptedInAt  DateTime?

  userId              String
  user                User                 @relation(fields: [userId], references: [id])
  messageLogs         MessageLog[]
  clinicalRecords     ClinicalRecord[]
  patientImages       PatientImage[]
  notes               Note[]
  appointments        Appointment[]
  alignerBatches      AlignerBatch[]
  reevaluations       Reevaluation[]
  alignerChangeEvents AlignerChangeEvent[]
  appointmentRecords  AppointmentRecord[]
  onboardingToken     OnboardingToken?

  @@unique([userId, rut])
  @@unique([userId, email])
  @@unique([userId, phone])
  @@index([userId])
  @@index([userId, clinic])
  @@index([userId, doctor])
}

model ClinicalRecord {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  diagnosis     String?
  treatmentPlan String?
  observations  String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

enum ImageType {
  PHOTO
  XRAY
}

model PatientImage {
  id          String    @id @default(cuid())
  url         String
  type        ImageType
  date        DateTime  @default(now())
  description String?
  category    String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model Note {
  id        String   @id @default(cuid())
  content   String
  color     String?  @default("yellow") // yellow, blue, pink, green
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Appointment {
  id          String            @id @default(cuid())
  title       String
  start       DateTime
  end         DateTime
  allDay      Boolean           @default(false)
  status      AppointmentStatus @default(SCHEDULED)
  description String?

  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id])

  todoistTaskId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
}

// MessageLog replaced by the new version at the bottom

enum Role {
  ADMIN
  STAFF
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  role      Role      @default(STAFF)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  patients  Patient[]
}

enum BatchStatus {
  NEEDED
  ORDER_SENT
  IN_PRODUCTION
  DELIVERED_TO_CLINIC
  HANDED_TO_PATIENT
  CANCELLED
}

model AlignerBatch {
  id                   String      @id @default(cuid())
  status               BatchStatus @default(NEEDED)
  orderDate            DateTime?
  expectedDeliveryDate DateTime?
  actualDeliveryDate   DateTime?
  notes                String?
  batchNumber          Int         @default(1)
  alignerCount         Int         @default(0)
  gooFileUrl           String?
  technicianEmail      String?
  technicianNotes      String?
  createdBy            String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  batchEvents BatchEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
}

model BatchEvent {
  id         String       @id @default(cuid())
  batchId    String
  batch      AlignerBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  fromStatus BatchStatus?
  toStatus   BatchStatus
  note       String?
  createdBy  String?

  createdAt DateTime @default(now())

  @@index([batchId])
}

enum ReevaluationStatus {
  NEEDED
  SCAN_UPLOADED
  APPROVED
}

model Reevaluation {
  id           String             @id @default(cuid())
  status       ReevaluationStatus @default(NEEDED)
  scanDate     DateTime?
  scanFileUrl  String?
  approvalDate DateTime?
  notes        String?
  createdBy    String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
}

enum MessageChannel {
  WHATSAPP
  EMAIL
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageTemplateType {
  ALIGNER_CHANGE_REMINDER
  APPOINTMENT_REMINDER_48H
  APPOINTMENT_REMINDER_2H
  BATCH_PICKUP_READY
  LAB_ORDER_REQUEST
  PROGRESS_MILESTONE_50
  MISSED_APPOINTMENT
  ORTHODONTIST_ALERT_BATCH_URGENT
  ORTHODONTIST_ALERT_WEEKLY_SUMMARY
  ORTHODONTIST_ALERT_OVERDUE_DELIVERY
  TREATMENT_COMPLETED
  WELCOME
  CHANGE_CONFIRMATION
  CHANGE_FOLLOWUP_NO
  FALLBACK_UNRECOGNIZED
  BATCH_ENDING_LAB_ALERT
  APPOINTMENT_NEEDED
}

model MessageTemplate {
  id        String              @id @default(cuid())
  name      String              @unique
  type      MessageTemplateType
  channel   MessageChannel
  content   String
  language  String              @default("es")
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  logs      MessageLog[]
}

enum MessageDirection {
  INCOMING
  OUTGOING
}

model MessageLog {
  id                String           @id @default(cuid())
  patientId         String?
  templateId        String?
  template          MessageTemplate? @relation(fields: [templateId], references: [id])
  channel           MessageChannel
  direction         MessageDirection @default(OUTGOING)
  recipient         String
  content           String
  status            MessageStatus    @default(PENDING)
  error             String?
  providerMessageId String?          @unique
  isRead            Boolean          @default(true)
  triggeredBy       MessageTrigger
  createdAt         DateTime         @default(now())

  patient           Patient?         @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([templateId])
}

model AlignerChangeEvent {
  id             String   @id @default(cuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  alignerNumber  Int
  confirmedAt    DateTime?
  confirmedBy    AlignerChangeReason?
  nextReminderAt DateTime
  createdAt      DateTime @default(now())

  @@index([patientId])
}

model AppointmentRecord {
  id               String    @id @default(cuid())
  patientId        String
  patient          Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentDate  DateTime
  alignersGiven    Int
  startingAligner  Int
  nextApptEstimate DateTime?
  createdAt        DateTime  @default(now())

  @@index([patientId])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String? // userId of the acting user; null for system/cron actions
  action    String // CREATE | UPDATE | DELETE
  entity    String // e.g. "Patient", "ClinicalRecord"
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorId])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model OnboardingToken {
  id          String    @id @default(cuid())
  patientId   String    @unique
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  token       String    @unique @default(cuid())
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
}

// Roster of Dentalink patients surfaced on the Controles page. `id` is the
// Dentalink patient ID (not a local cuid) so it maps directly to their API.
// Seeded once from the DENTALINK_PATIENT_IDS env var, then editable at runtime.
model DentalinkPatient {
  id        Int      @id
  nombre    String
  createdAt DateTime @default(now())
}
