generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PatientStatus {
  ACTIVE
  PAUSED
  FINISHED
}

model Patient {
  id                 String        @id @default(cuid())
  rut                String        @unique
  fullName           String
  phone              String        @unique
  email              String        @unique
  treatmentStartDate DateTime
  changeFrequency    Int
  wearDaysPerAligner Int           @default(14)
  totalAligners      Int           @default(0)
  currentAligner     Int           @default(1)
  batchPhase         Int           @default(1)
  batchStartDate     DateTime?
  status             PatientStatus @default(ACTIVE)
  avatarUrl          String?
  diagnosis          String?
  treatmentPlan      String?
  observations       String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  userId          String
  user            User             @relation(fields: [userId], references: [id])
  messageLogs     MessageLog[]
  clinicalRecords ClinicalRecord[]
  patientImages   PatientImage[]
  notes           Note[]
  appointments    Appointment[]
  alignerBatches  AlignerBatch[]
  reevaluations   Reevaluation[]
}

model ClinicalRecord {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  diagnosis     String?
  treatmentPlan String?
  observations  String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

enum ImageType {
  PHOTO
  XRAY
}

model PatientImage {
  id          String    @id @default(cuid())
  url         String
  type        ImageType
  date        DateTime  @default(now())
  description String?
  category    String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  content   String
  color     String?  @default("yellow") // yellow, blue, pink, green
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Appointment {
  id          String            @id @default(cuid())
  title       String
  start       DateTime
  end         DateTime
  allDay      Boolean           @default(false)
  status      AppointmentStatus @default(SCHEDULED)
  description String?

  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id])

  todoistTaskId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MessageLog {
  id             String   @id @default(cuid())
  sentAt         DateTime @default(now())
  status         String
  messageContent String

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  patients  Patient[]
}

enum BatchStatus {
  NEEDED
  ORDER_SENT
  IN_PRODUCTION
  DELIVERED_TO_CLINIC
  HANDED_TO_PATIENT
  CANCELLED
}

model AlignerBatch {
  id                   String      @id @default(cuid())
  status               BatchStatus @default(NEEDED)
  orderDate            DateTime?
  expectedDeliveryDate DateTime?
  actualDeliveryDate   DateTime?
  notes                String?
  batchNumber          Int         @default(1)
  alignerCount         Int         @default(0)
  technicianEmail      String?
  technicianNotes      String?
  createdBy            String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  batchEvents BatchEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BatchEvent {
  id         String       @id @default(cuid())
  batchId    String
  batch      AlignerBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  fromStatus BatchStatus?
  toStatus   BatchStatus
  note       String?
  createdBy  String?

  createdAt DateTime @default(now())
}

enum ReevaluationStatus {
  NEEDED
  SCAN_UPLOADED
  APPROVED
}

model Reevaluation {
  id           String             @id @default(cuid())
  status       ReevaluationStatus @default(NEEDED)
  scanDate     DateTime?
  scanFileUrl  String?
  approvalDate DateTime?
  notes        String?
  createdBy    String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
