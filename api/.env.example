# ── Core (required) ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/orthoreminder?schema=public"
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=""
NODE_ENV=development
# Comma-separated browser origins allowed by CORS (required in production)
ALLOWED_ORIGINS=

# ── Cloudflare R2 (required: patient image/avatar storage) ───────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional explicit endpoint (defaults to https://<account>.r2.cloudflarestorage.com)
R2_ENDPOINT=

# ── Bootstrap admin (used by `prisma db seed` to create the first user) ──────
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=

# ── Twilio (optional: WhatsApp via Twilio) ───────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# ── Meta WhatsApp Cloud API (optional) ───────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# ── Resend (optional: transactional email) ───────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=

# ── Todoist (optional: appointment sync) ─────────────────────────────────────
TODOIST_API_TOKEN=

# ── Dentalink (optional: Controles / patient history page) ───────────────────
DENTALINK_TOKEN=
# Patient list, entries separated by ";", each "id:Full Name"
DENTALINK_PATIENT_IDS=
